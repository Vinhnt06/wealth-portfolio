{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/signout/layout,_N_T_/signout/page,_N_T_/signout"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/signout/__PAGE__",
    "/signout",
    "/_index",
    "/_head"
  ]
}